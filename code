function drawGrass(ctx: CanvasRenderingContext2D) {
  const totalW = WORLD_W * TILE;
  const totalH = WORLD_H * TILE;

  // Base grass with subtle texture
  ctx.fillStyle = "#4ade80";
  ctx.fillRect(0, 0, totalW, totalH);

  // Lighter patches for texture
  ctx.fillStyle = "#57e88d";
  for (let gx = 0; gx < WORLD_W; gx++) {
    for (let gy = 0; gy < WORLD_H; gy++) {
      if ((gx + gy) % 3 === 0) {
        ctx.fillRect(gx * TILE + 8, gy * TILE + 8, TILE - 16, TILE - 16);
      }
    }
  }

  // Darker border forest
  ctx.fillStyle = "#166534";
  ctx.fillRect(-100, -100, totalW + 200, 100);
  ctx.fillRect(-100, totalH, totalW + 200, 100);
  ctx.fillRect(-100, 0, 100, totalH);
  ctx.fillRect(totalW, 0, 100, totalH);

  // Stone paths
  ctx.fillStyle = "#d1d5db";
  const cx = totalW / 2;
  const cy = totalH / 2;
  ctx.fillRect(cx - 26, 0, 52, totalH);
  ctx.fillRect(0, cy - 26, totalW, 52);

  // Path stones texture
  ctx.fillStyle = "#c9cdd5";
  for (let i = 0; i < 18; i++) {
    ctx.fillRect(cx - 20, i * 72 + 10, 16, 52);
    ctx.fillRect(cx + 4,  i * 72 + 36, 16, 52);
    ctx.fillRect(i * 72 + 10, cy - 20, 52, 16);
    ctx.fillRect(i * 72 + 36, cy + 4,  52, 16);
  }

  // Central plaza
  ctx.fillStyle = "#e5e7eb";
  ctx.beginPath();
  ctx.arc(cx, cy, 88, 0, Math.PI * 2);
  ctx.fill();

  // Plaza stone ring
  ctx.strokeStyle = "#d1d5db";
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.arc(cx, cy, 82, 0, Math.PI * 2);
  ctx.stroke();

  // Fountain basin
  ctx.fillStyle = "#9ca3af";
  ctx.beginPath();
  ctx.arc(cx, cy, 40, 0, Math.PI * 2);
  ctx.fill();
  // Water
  ctx.fillStyle = "#7dd3fc";
  ctx.globalAlpha = 0.9;
  ctx.beginPath();
  ctx.arc(cx, cy, 32, 0, Math.PI * 2);
  ctx.fill();
  ctx.globalAlpha = 1;
  // Center pillar
  ctx.fillStyle = "#6b7280";
  ctx.beginPath();
  ctx.arc(cx, cy, 9, 0, Math.PI * 2);
  ctx.fill();
  ctx.fillStyle = "#e2e8f0";
  ctx.beginPath();
  ctx.arc(cx, cy, 5, 0, Math.PI * 2);
  ctx.fill();
}

