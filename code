function drawDog(
  ctx: CanvasRenderingContext2D,
  x: number, y: number,
  time: number,
  happyTimer: number,
  facing: number,
) {
  ctx.save();
  ctx.translate(x, y);
  if (facing < 0) ctx.scale(-1, 1);
  const t = time / 1000;
  const moving = true;

  // Shadow
  ctx.fillStyle = "rgba(0,0,0,0.18)";
  ctx.beginPath();
  ctx.ellipse(2, 8, 17, 5, 0, 0, Math.PI * 2);
  ctx.fill();

  // Wagging tail
  const wag = Math.sin(t * (happyTimer > 0 ? 14 : 7)) * 0.55;
  ctx.save();
  ctx.translate(-13, -7);
  ctx.rotate(wag);
  ctx.fillStyle = "#b45309";
  ctx.beginPath();
  ctx.ellipse(0, -7, 3, 7, 0.15, 0, Math.PI * 2);
  ctx.fill();
  ctx.restore();

  // Back legs
  const legB = Math.sin(t * 6 + Math.PI) * 3;
  ctx.fillStyle = "#b45309";
  ctx.fillRect(-9, 2 + legB, 5, 9);
  ctx.fillRect(-2, 2 - legB, 5, 9);
  // Paws (back)
  ctx.fillStyle = "#fde68a";
  ctx.beginPath(); ctx.arc(-7, 11 + legB, 3, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(1, 11 - legB, 3, 0, Math.PI * 2); ctx.fill();

  // Body
  ctx.fillStyle = "#d97706";
  ctx.beginPath();
  ctx.ellipse(0, -4, 15, 10, 0, 0, Math.PI * 2);
  ctx.fill();
  // Belly patch
  ctx.fillStyle = "#fde68a";
  ctx.beginPath();
  ctx.ellipse(2, -2, 9, 6, 0, 0, Math.PI * 2);
  ctx.fill();

  // Front legs
  const legF = Math.sin(t * 6) * 3;
  ctx.fillStyle = "#b45309";
  ctx.fillRect(8,  2 + legF, 5, 9);
  ctx.fillRect(15, 2 - legF, 5, 9);
  // Paws (front)
  ctx.fillStyle = "#fde68a";
  ctx.beginPath(); ctx.arc(10, 11 + legF, 3, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(17, 11 - legF, 3, 0, Math.PI * 2); ctx.fill();

  // Neck
  ctx.fillStyle = "#d97706";
  ctx.beginPath(); ctx.arc(14, -9, 7, 0, Math.PI * 2); ctx.fill();

  // Floppy ear (behind head)
  ctx.fillStyle = "#92400e";
  ctx.save();
  ctx.translate(12, -13);
  ctx.rotate(-0.15 + Math.sin(t * 2.5) * 0.06);
  ctx.beginPath(); ctx.ellipse(0, 6, 5, 9, 0, 0, Math.PI * 2); ctx.fill();
  ctx.restore();

  // Head
  ctx.fillStyle = "#d97706";
  ctx.beginPath(); ctx.arc(16, -13, 11, 0, Math.PI * 2); ctx.fill();

  // Snout
  ctx.fillStyle = "#fde68a";
  ctx.beginPath(); ctx.ellipse(23, -11, 6, 5, 0, 0, Math.PI * 2); ctx.fill();

  // Nose
  ctx.fillStyle = "#1c1917";
  ctx.beginPath(); ctx.arc(27, -12, 2.5, 0, Math.PI * 2); ctx.fill();

  // Eye
  ctx.fillStyle = "#1c1917";
  ctx.beginPath(); ctx.arc(19, -16, 3.2, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = "#fff";
  ctx.beginPath(); ctx.arc(20, -17, 1.3, 0, Math.PI * 2); ctx.fill();

  // Tongue
  if (happyTimer > 0 || Math.sin(t * 0.9) > 0.75) {
    ctx.fillStyle = "#f87171";
    ctx.beginPath(); ctx.ellipse(26, -8, 3, 4.5, 0.1, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = "#fca5a5";
    ctx.beginPath(); ctx.arc(26, -6, 1.5, 0, Math.PI * 2); ctx.fill();
  }

  // Floating hearts when happy
  if (happyTimer > 0) {
    for (let i = 0; i < 4; i++) {
      const hx = -12 + i * 11 + Math.sin(t * 3 + i * 1.5) * 5;
      const hy2 = -30 - (1 - happyTimer) * 45;
      ctx.globalAlpha = Math.min(1, happyTimer * 2);
      ctx.font = `${10 + i * 3}px serif`;
      ctx.textAlign = "center";
      ctx.fillText(i % 2 === 0 ? "❤️" : "💕", hx, hy2);
    }
    ctx.globalAlpha = 1;
  }

  ctx.restore();
}

function drawBush(ctx: CanvasRenderingContext2D, x: number, y: number) {
  ctx.fillStyle = "#15803d";
  ctx.beginPath();
  ctx.arc(x - 10, y, 14, 0, Math.PI * 2);
  ctx.fill();
  ctx.fillStyle = "#16a34a";
  ctx.beginPath();
  ctx.arc(x + 8, y, 12, 0, Math.PI * 2);
  ctx.fill();
  ctx.fillStyle = "#22c55e";
  ctx.beginPath();
  ctx.arc(x, y - 8, 13, 0, Math.PI * 2);
  ctx.fill();
}

function drawLamp(ctx: CanvasRenderingContext2D, x: number, y: number, time: number) {
  const pulse = 0.6 + Math.sin(time * 0.001) * 0.08;
  // Glow on ground
  ctx.save();
  ctx.globalAlpha = 0.18 * pulse;
  const grad = ctx.createRadialGradient(x, y, 0, x, y, 55);
  grad.addColorStop(0, "#fde68a");
  grad.addColorStop(1, "transparent");
  ctx.fillStyle = grad;
  ctx.beginPath();
  ctx.arc(x, y, 55, 0, Math.PI * 2);
  ctx.fill();
  ctx.restore();
  // Pole
  ctx.fillStyle = "#374151";
  ctx.fillRect(x - 3, y - 55, 6, 55);
  // Arm
  ctx.fillStyle = "#374151";
