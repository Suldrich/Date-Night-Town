  ctx.beginPath();
  ctx.moveTo(x - 12, y + 18);
  ctx.lineTo(wx, y - 32);
  ctx.lineTo(wx, y + 18);
  ctx.closePath();
  ctx.fill();

  // Chimney
  ctx.fillStyle = "#6b7280";
  ctx.fillRect(x + w - 28, y - 22, 14, 24);
  ctx.fillStyle = "#4b5563";
  ctx.fillRect(x + w - 30, y - 22, 18, 5);

