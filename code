function drawShed(
  ctx: CanvasRenderingContext2D,
  option: DateOption,
  wx: number,
  wy: number,
  isNear: boolean,
  time: number,
) {
  const w = 96, h = 62;
  const x = wx - w / 2;
  const y = wy - h;

  // Glow when near
  if (isNear) {
    ctx.shadowColor = "#84cc16";
    ctx.shadowBlur = 22 + Math.sin(time * 4) * 6;
  }

  // Foundation
  ctx.fillStyle = "#713f12";
  ctx.fillRect(x - 2, y + h - 4, w + 4, 6);

  // Walls — wood planks (warm brown)
  ctx.fillStyle = "#92400e";
  ctx.fillRect(x, y, w, h);

  // Wood plank lines
  ctx.strokeStyle = "#78350f";
  ctx.lineWidth = 1.5;
  for (let i = 0; i < 5; i++) {
    const py2 = y + i * 12 + 6;
    ctx.beginPath();
    ctx.moveTo(x, py2);
    ctx.lineTo(x + w, py2);
    ctx.stroke();
  }
  // Vertical plank dividers
  ctx.strokeStyle = "#6b3009";
  ctx.lineWidth = 1;
  for (let i = 1; i < 5; i++) {
    const px2 = x + i * (w / 5);
    ctx.beginPath();
    ctx.moveTo(px2, y);
    ctx.lineTo(px2, y + h);
    ctx.stroke();
  }

  ctx.shadowBlur = 0;
  ctx.shadowColor = "transparent";

  // Shed roof — asymmetric (taller on left, slopes right)
  ctx.fillStyle = option.roofColor;
  ctx.beginPath();
  ctx.moveTo(x - 8, y);             // bottom left
  ctx.lineTo(wx - 10, y - 36);      // peak (left of center)
  ctx.lineTo(x + w + 8, y + 6);     // bottom right
  ctx.closePath();
  ctx.fill();

  // Roof trim
  ctx.strokeStyle = "#1c3a0b";
  ctx.lineWidth = 2;
  ctx.stroke();

  // Door — arched, wooden
  ctx.fillStyle = "#5c2d09";
  ctx.beginPath();
  ctx.roundRect(wx - 10, y + h - 30, 20, 30, [5, 5, 0, 0]);
  ctx.fill();
  // Door hinge
  ctx.fillStyle = "#ca8a04";
  ctx.fillRect(wx - 8, y + h - 24, 3, 10);

  // Window — with flower box
  const winX = x + 12, winY = y + 8;
  ctx.fillStyle = "#bef264";
  ctx.fillRect(winX, winY, 22, 16);
  ctx.strokeStyle = "#78350f";
  ctx.lineWidth = 2;
  ctx.strokeRect(winX, winY, 22, 16);
  // Pane cross
  ctx.beginPath();
  ctx.moveTo(winX + 11, winY); ctx.lineTo(winX + 11, winY + 16);
  ctx.moveTo(winX, winY + 8);  ctx.lineTo(winX + 22, winY + 8);
  ctx.stroke();
  // Flower box under window
  ctx.fillStyle = "#78350f";
  ctx.fillRect(winX - 2, winY + 16, 26, 6);
  // Flowers in box
  const boxFlowers = ["#f43f5e", "#fbbf24", "#a78bfa", "#34d399", "#60a5fa"];
  for (let i = 0; i < 5; i++) {
    ctx.fillStyle = boxFlowers[i % boxFlowers.length];
    ctx.beginPath();
    ctx.arc(winX + 2 + i * 5, winY + 14, 3, 0, Math.PI * 2);
    ctx.fill();
  }

  // Garden tools leaning against right wall
  const toolX = x + w - 14;
  // Rake/shovel handle
  ctx.strokeStyle = "#92400e";
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.moveTo(toolX, y + h);
  ctx.lineTo(toolX - 8, y + 10);
  ctx.stroke();
  // Rake head
  ctx.fillStyle = "#6b7280";
  ctx.fillRect(toolX - 16, y + 10, 18, 4);
  ctx.strokeStyle = "#4b5563";
  ctx.lineWidth = 1;
  for (let i = 0; i < 4; i++) {
    ctx.beginPath();
    ctx.moveTo(toolX - 14 + i * 5, y + 14);
    ctx.lineTo(toolX - 14 + i * 5, y + 20);
    ctx.stroke();
  }
  // Second tool
  ctx.strokeStyle = "#92400e";
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.moveTo(toolX + 8, y + h);
  ctx.lineTo(toolX + 3, y + 14);
  ctx.stroke();
  ctx.fillStyle = "#b45309";
  ctx.fillRect(toolX - 1, y + 12, 12, 8);

  // Small garden patch in front
  ctx.fillStyle = "#713f12";
  ctx.fillRect(wx - 24, wy + 4, 48, 12);
  ctx.strokeStyle = "#92400e";
  ctx.lineWidth = 1;
  ctx.strokeRect(wx - 24, wy + 4, 48, 12);
  // Seedlings
  for (let i = 0; i < 4; i++) {
    const sx = wx - 18 + i * 12;
    ctx.fillStyle = "#4ade80";
    ctx.fillRect(sx - 1, wy + 2, 2, 10);
    ctx.beginPath();
    ctx.arc(sx, wy + 2, 4, 0, Math.PI * 2);
    ctx.fill();
  }

  // Vines on left edge
  ctx.strokeStyle = "#16a34a";
  ctx.lineWidth = 2;
  for (let i = 0; i < 3; i++) {
    const vy = y + 10 + i * 16;
    ctx.beginPath();
    ctx.moveTo(x, vy);
    ctx.quadraticCurveTo(x - 8, vy + 6, x - 3, vy + 12);
    ctx.stroke();
    ctx.fillStyle = "#22c55e";
    ctx.beginPath();
    ctx.arc(x - 6, vy + 8, 5, 0, Math.PI * 2);
    ctx.fill();
  }

  // Sign
  ctx.fillStyle = "#fef3c7";
  ctx.fillRect(wx - 30, y + h - 52, 60, 14);
  ctx.fillStyle = "#14532d";
  ctx.font = "bold 8px sans-serif";
  ctx.textAlign = "center";
  ctx.fillText(option.name, wx, y + h - 41);

  // Emoji
  ctx.font = "22px serif";
  ctx.fillText(option.emoji, wx, y - 42);
}

function drawCasino(
  ctx: CanvasRenderingContext2D,
  option: DateOption,
  wx: number,
  wy: number,
  isNear: boolean,
  time: number,
) {
  const w = 100, h = 70;
  const x = wx - w / 2;
  const y = wy - h;

  // Pulsing neon glow
  const pulse = Math.sin(time * 3) * 0.5 + 0.5;
  if (isNear) {
    ctx.shadowColor = "#fbbf24";
    ctx.shadowBlur = 28 + pulse * 12;
  } else {
    ctx.shadowColor = "#fbbf24";
    ctx.shadowBlur = 8 + pulse * 6;
  }

  // Foundation
  ctx.fillStyle = "#1c1917";
  ctx.fillRect(x - 3, y + h - 4, w + 6, 6);

  // Walls — dark purple/maroon
  ctx.fillStyle = "#1c0533";
  ctx.fillRect(x, y, w, h);

  // Gold trim on walls
  ctx.strokeStyle = "#fbbf24";
  ctx.lineWidth = 2;
  ctx.strokeRect(x + 4, y + 4, w - 8, h - 8);

  // Decorative gold diamonds pattern
  ctx.fillStyle = "#fbbf2422";
  for (let i = 0; i < 3; i++) {
    for (let j = 0; j < 2; j++) {
      const dx2 = x + 14 + i * 28, dy2 = y + 12 + j * 26;
      ctx.save();
      ctx.translate(dx2, dy2);
      ctx.rotate(Math.PI / 4);
      ctx.fillRect(-6, -6, 12, 12);
      ctx.restore();
    }
  }

  ctx.shadowBlur = 0;
  ctx.shadowColor = "transparent";

  // Fancy roof — flat top with gold crenellations
  ctx.fillStyle = "#3b0764";
  ctx.fillRect(x - 8, y - 14, w + 16, 18);
  // Crenellations
  ctx.fillStyle = "#fbbf24";
  for (let i = 0; i < 7; i++) {
    ctx.fillRect(x - 6 + i * 16, y - 22, 10, 12);
  }
  // Roof trim
  ctx.strokeStyle = "#fbbf24";
  ctx.lineWidth = 1.5;
  ctx.strokeRect(x - 8, y - 14, w + 16, 18);

  // Marquee sign — neon
  const signW = 76, signH = 18;
  const sx = wx - signW / 2, sy = y + 6;
  ctx.fillStyle = "#0f0320";
  ctx.fillRect(sx, sy, signW, signH);
  ctx.strokeStyle = `rgba(251,191,36,${0.6 + pulse * 0.4})`;
  ctx.lineWidth = 2;
  ctx.strokeRect(sx, sy, signW, signH);
  // Marquee dots
  for (let i = 0; i < 8; i++) {
    ctx.fillStyle = i % 2 === Math.floor(time * 3) % 2
      ? "#fbbf24" : "#78350f";
    ctx.beginPath();
    ctx.arc(sx + 5 + i * 9, sy + 9, 2.5, 0, Math.PI * 2);
    ctx.fill();
  }
  ctx.fillStyle = "#fbbf24";
  ctx.font = "bold 8px sans-serif";
  ctx.textAlign = "center";
  ctx.fillText("CASINO", wx, sy + 12);

  // Door — velvet red
  ctx.fillStyle = "#7f1d1d";
  ctx.fillRect(wx - 11, y + h - 32, 22, 32);
  ctx.strokeStyle = "#fbbf24";
  ctx.lineWidth = 1.5;
  ctx.strokeRect(wx - 11, y + h - 32, 22, 32);
  // Door handle
  ctx.fillStyle = "#fbbf24";
  ctx.beginPath();
  ctx.arc(wx + 6, y + h - 16, 2, 0, Math.PI * 2);
  ctx.fill();

  // Windows — glowing purple
  for (const wox of [-32, 28]) {
    const winX = wx + wox, winY = y + 16;
    ctx.fillStyle = `rgba(139,92,246,${0.4 + pulse * 0.3})`;
    ctx.fillRect(winX, winY, 16, 14);
    ctx.strokeStyle = "#fbbf24";
    ctx.lineWidth = 1;
    ctx.strokeRect(winX, winY, 16, 14);
  }

  // Stars / sparkles floating above
  for (let i = 0; i < 4; i++) {
    const angle = time * 1.5 + i * (Math.PI / 2);
    const starX = wx + Math.cos(angle) * 28;
    const starY = (y - 30) + Math.sin(angle * 2) * 6;
    ctx.fillStyle = `rgba(251,191,36,${0.5 + Math.sin(angle * 3) * 0.4})`;
    ctx.font = "10px serif";
    ctx.fillText("✦", starX, starY);
  }

  // Emoji above
  ctx.font = "22px serif";
  ctx.textAlign = "center";
  ctx.fillText(option.emoji, wx, y - 30);
}

function drawPlayer(
  ctx: CanvasRenderingContext2D,
  px: number,
  py: number,
  bobY: number,
  config: CharConfig,
) {
  ctx.save();
  ctx.translate(px, py + bobY);

  // Name tag above head
  if (config.name) {
    ctx.font = "bold 11px sans-serif";
    ctx.textAlign = "center";
    const tw = ctx.measureText(config.name).width + 10;
    ctx.fillStyle = "rgba(0,0,0,0.55)";
    ctx.beginPath();
    ctx.roundRect(-tw / 2, -54, tw, 16, 5);
    ctx.fill();
    ctx.fillStyle = "#fff";
    ctx.fillText(config.name, 0, -41);
  }

  // Shadow
  ctx.fillStyle = "rgba(0,0,0,0.22)";
  ctx.beginPath();
  ctx.ellipse(0, 15, 17, 7, 0, 0, Math.PI * 2);
  ctx.fill();

  // Legs
  ctx.fillStyle = "#6366f1";
  ctx.fillRect(-10, 8, 9, 16);
  ctx.fillRect(1, 8, 9, 16);

  // Body
  ctx.fillStyle = config.bodyColor;
  ctx.fillRect(-14, -10, 28, 22);
  ctx.fillStyle = "rgba(255,255,255,0.2)";
  ctx.fillRect(-14, -10, 9, 22);

  // Head
  ctx.fillStyle = "#fde68a";
  ctx.fillRect(-13, -30, 26, 24);

  // Hair
  ctx.fillStyle = config.hairColor;
  ctx.fillRect(-13, -34, 26, 13);
  // Hair wisp
  ctx.fillRect(-16, -34, 6, 10);

  // Eyes
  ctx.fillStyle = "#1e1b4b";
  ctx.fillRect(-7, -21, 5, 6);
  ctx.fillRect(2, -21, 5, 6);
  // Eye shine
  ctx.fillStyle = "#fff";
  ctx.fillRect(-6, -21, 2, 2);
  ctx.fillRect(3, -21, 2, 2);

  // Blush
  ctx.fillStyle = "rgba(255,100,100,0.35)";
  ctx.beginPath();
  ctx.arc(-9, -13, 4, 0, Math.PI * 2);
  ctx.arc(9, -13, 4, 0, Math.PI * 2);
  ctx.fill();

  ctx.restore();
}

// ─── Game component ───────────────────────────────────────────────────────────

export default function Game() {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const stateRef = useRef({
    playerX: 640,
    playerY: 640,
    keys: new Set<string>(),
    bobTime: 0,
    bobY: 0,
    facingAngle: 0,
    time: 0,
  });
  const joystickRef = useRef({ dx: 0, dy: 0 });
  const isMobile = useIsMobile();
  const [nearOption, setNearOption] = useState<DateOption | null>(null);
  const [activeOption, setActiveOption] = useState<DateOption | null>(null);
  const nearOptionRef = useRef<DateOption | null>(null);
  const activeOptionRef = useRef<DateOption | null>(null);
  const [nearShop, setNearShop] = useState<SmallBuilding | null>(null);
  const [activeShop, setActiveShop] = useState<SmallBuilding | null>(null);
  const nearShopRef = useRef<SmallBuilding | null>(null);
  const activeShopRef = useRef<SmallBuilding | null>(null);
  const animRef = useRef<number>(0);
  const [charConfig, setCharConfig] = useState<CharConfig>(() => loadConfig());
  const charConfigRef = useRef<CharConfig>(charConfig);
  const [customizerOpen, setCustomizerOpen] = useState(false);
  const [casinoOpen, setCasinoOpen] = useState(false);
  const dogRef = useRef({ x: 530, y: 420, vx: 55, vy: 30, wanderTimer: 2.5, happyTimer: 0, facing: 1 });
  const [nearDog, setNearDog] = useState(false);
  const nearDogRef = useRef(false);

  const handleJoystick = useCallback((dx: number, dy: number) => {
    joystickRef.current = { dx, dy };
  }, []);

  useEffect(() => {
    const onKey = (e: KeyboardEvent) => {
      if (e.type === "keydown") {
        stateRef.current.keys.add(e.code);
        if (e.code === "KeyE") {
          if (nearDogRef.current && !activeOptionRef.current && !activeShopRef.current) {
            dogRef.current.happyTimer = 1.8;
          } else if (nearOptionRef.current && !activeOptionRef.current && !activeShopRef.current) {
            setActiveOption(nearOptionRef.current);
            activeOptionRef.current = nearOptionRef.current;
          } else if (nearShopRef.current && !activeShopRef.current && !activeOptionRef.current) {
            setActiveShop(nearShopRef.current);
            activeShopRef.current = nearShopRef.current;
          }
        }
        if (e.code === "Escape") {
          if (activeOptionRef.current) { setActiveOption(null); activeOptionRef.current = null; }
          if (activeShopRef.current)   { setActiveShop(null);   activeShopRef.current = null; }
        }
      } else {
        stateRef.current.keys.delete(e.code);
      }
    };
    window.addEventListener("keydown", onKey);
    window.addEventListener("keyup", onKey);
    return () => {
      window.removeEventListener("keydown", onKey);
      window.removeEventListener("keyup", onKey);
    };
  }, []);

  useEffect(() => { activeOptionRef.current = activeOption; }, [activeOption]);
  useEffect(() => { activeShopRef.current = activeShop; }, [activeShop]);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;

    const resize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };
    resize();
    window.addEventListener("resize", resize);

    let last = performance.now();

    const loop = (now: number) => {
      const dt = Math.min((now - last) / 1000, 0.05);
      last = now;
      const s = stateRef.current;
      s.time = now;

      const paused = !!activeOptionRef.current || !!activeShopRef.current;

      if (!paused) {
        let dx = joystickRef.current.dx;
        let dy = joystickRef.current.dy;
        if (s.keys.has("KeyW") || s.keys.has("ArrowUp"))    dy -= 1;
        if (s.keys.has("KeyS") || s.keys.has("ArrowDown"))  dy += 1;
        if (s.keys.has("KeyA") || s.keys.has("ArrowLeft"))  dx -= 1;
        if (s.keys.has("KeyD") || s.keys.has("ArrowRight")) dx += 1;

        const moving = dx !== 0 || dy !== 0;
        if (moving) {
          const len = Math.sqrt(dx * dx + dy * dy);
          dx /= len; dy /= len;
          s.facingAngle = Math.atan2(dx, -dy);
          s.bobTime += dt * 8;
          s.bobY = Math.abs(Math.sin(s.bobTime)) * -5;
        } else {
          s.bobY = s.bobY * 0.8;
        }

        const speed = PLAYER_SPEED * TILE * dt;
        const worldSize = WORLD_W * TILE;
        s.playerX = Math.max(48, Math.min(worldSize - 48, s.playerX + dx * speed));
        s.playerY = Math.max(48, Math.min(worldSize - 48, s.playerY + dy * speed));

        let found: DateOption | null = null;
        let foundDist = Infinity;
        for (const opt of DATE_OPTIONS) {
          const hp = HOUSE_POSITIONS[opt.id];
          if (!hp) continue;
          const d = Math.hypot(s.playerX - hp.wx, s.playerY - hp.wy);
          if (d < ENTER_DISTANCE && d < foundDist) {
            foundDist = d;
            found = opt;
          }
        }
        if (found?.id !== nearOptionRef.current?.id) {
          nearOptionRef.current = found;
          setNearOption(found);
        }

        // Shop proximity
        let foundShop: SmallBuilding | null = null;
        let foundShopDist = Infinity;
        for (const b of SMALL_BUILDINGS) {
          const d = Math.hypot(s.playerX - b.wx, s.playerY - b.wy);
          if (d < SHOP_ENTER_DISTANCE && d < foundShopDist) {
            foundShopDist = d;
            foundShop = b;
          }
        }
        if (foundShop?.label !== nearShopRef.current?.label) {
          nearShopRef.current = foundShop;
          setNearShop(foundShop);
        }

        // Dog AI
        const dog = dogRef.current;
        const worldSize2 = WORLD_W * TILE;
        dog.wanderTimer -= dt;
        const distToPlayer = Math.hypot(s.playerX - dog.x, s.playerY - dog.y);

        if (distToPlayer < DOG_EXCITE_DIST) {
          // Excited — run toward player
          const ddx = s.playerX - dog.x, ddy = s.playerY - dog.y;
          const dlen = Math.sqrt(ddx * ddx + ddy * ddy) || 1;
          dog.vx = (ddx / dlen) * DOG_SPEED * 1.3;
          dog.vy = (ddy / dlen) * DOG_SPEED * 1.3;
        } else if (dog.wanderTimer <= 0) {
          const angle = Math.random() * Math.PI * 2;
          dog.vx = Math.cos(angle) * DOG_SPEED;
          dog.vy = Math.sin(angle) * DOG_SPEED;
          dog.wanderTimer = 2 + Math.random() * 3;
        }
        dog.x = Math.max(60, Math.min(worldSize2 - 60, dog.x + dog.vx * dt));
        dog.y = Math.max(60, Math.min(worldSize2 - 60, dog.y + dog.vy * dt));
        if (dog.x <= 60 || dog.x >= worldSize2 - 60) { dog.vx *= -1; dog.wanderTimer = 0; }
        if (dog.y <= 60 || dog.y >= worldSize2 - 60) { dog.vy *= -1; dog.wanderTimer = 0; }
        if (Math.abs(dog.vx) > 0.1) dog.facing = dog.vx > 0 ? 1 : -1;
        if (dog.happyTimer > 0) dog.happyTimer -= dt;

        const isNearDog = distToPlayer < DOG_PET_DISTANCE;
        if (isNearDog !== nearDogRef.current) {
          nearDogRef.current = isNearDog;
          setNearDog(isNearDog);
        }
      }

      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      const camX = canvas.width / 2 - s.playerX;
      const camY = canvas.height / 2 - s.playerY;

      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = "#166534";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.save();
      ctx.translate(camX, camY);

      // World ground
      drawGrass(ctx);

      // ── Lamps (always rendered, glow at ground level first)
      for (const [lx, ly] of LAMP_POSITIONS) {
        drawLamp(ctx, lx as number, ly as number, now);
      }

      // ── Benches (low, always)
      for (const b of BENCH_POSITIONS) {
        drawBench(ctx, b.x, b.y);
      }

      // ── Flowers (always)
      for (const [fx, fy, fc, ft, fs] of FLOWER_POSITIONS) {
        drawFlower(ctx, fx, fy, fc, ft as string, fs as number);
      }

      // ── Trees behind player
      for (const [tx, ty] of TREE_POSITIONS) {
        if ((ty as number) > s.playerY) continue;
        drawTree(ctx, tx as number, ty as number);
      }

      // ── Small buildings behind player
      for (const b of SMALL_BUILDINGS) {
        if (b.wy + 40 > s.playerY) continue;
        drawSmallBuilding(ctx, b, nearShopRef.current?.label === b.label);
      }

      // ── Main houses behind player
      for (const opt of DATE_OPTIONS) {
        const hp = HOUSE_POSITIONS[opt.id];
        if (!hp || hp.wy + 60 > s.playerY) continue;
        const near = nearOptionRef.current?.id === opt.id;
        if (opt.id === "diy") drawShed(ctx, opt, hp.wx, hp.wy, near, now);
        else if (opt.id === "casino") drawCasino(ctx, opt, hp.wx, hp.wy, near, now);
        else drawHouse(ctx, hp.wx, hp.wy, opt, near, now);
      }

      // ── Dog and Player — z-sorted together
      const dog = dogRef.current;
      if (dog.y < s.playerY) {
        drawDog(ctx, dog.x, dog.y, now, dog.happyTimer, dog.facing);
        drawPlayer(ctx, s.playerX, s.playerY, s.bobY, charConfigRef.current);
      } else {
        drawPlayer(ctx, s.playerX, s.playerY, s.bobY, charConfigRef.current);
        drawDog(ctx, dog.x, dog.y, now, dog.happyTimer, dog.facing);
      }

      // ── Main houses in front of player
      for (const opt of DATE_OPTIONS) {
        const hp = HOUSE_POSITIONS[opt.id];
        if (!hp || hp.wy + 60 <= s.playerY) continue;
        const near = nearOptionRef.current?.id === opt.id;
        if (opt.id === "diy") drawShed(ctx, opt, hp.wx, hp.wy, near, now);
        else if (opt.id === "casino") drawCasino(ctx, opt, hp.wx, hp.wy, near, now);
        else drawHouse(ctx, hp.wx, hp.wy, opt, near, now);
      }

      // ── Small buildings in front of player
      for (const b of SMALL_BUILDINGS) {
        if (b.wy + 40 <= s.playerY) continue;
        drawSmallBuilding(ctx, b, nearShopRef.current?.label === b.label);
      }

      // ── Trees in front of player
      for (const [tx, ty] of TREE_POSITIONS) {
        if ((ty as number) <= s.playerY) continue;
        drawTree(ctx, tx as number, ty as number);
      }

      ctx.restore();

      animRef.current = requestAnimationFrame(loop);
    };

    animRef.current = requestAnimationFrame(loop);
    return () => {
      cancelAnimationFrame(animRef.current);
      window.removeEventListener("resize", resize);
    };
  }, []);

  const handleEnter = useCallback(() => {
    const opt = nearOptionRef.current;
    if (!opt) return;
    if (opt.id === "casino") {
      setCasinoOpen(true);
    } else {
      setActiveOption(opt);
      activeOptionRef.current = opt;
    }
  }, []);

  const handleEnterShop = useCallback(() => {
    if (nearShopRef.current) {
      setActiveShop(nearShopRef.current);
      activeShopRef.current = nearShopRef.current;
    }
  }, []);

  const anyOpen = !!activeOption || !!activeShop || customizerOpen || casinoOpen;

  return (
    <div style={{ width: "100%", height: "100%", position: "relative", overflow: "hidden" }}>
      <canvas
        ref={canvasRef}
        style={{ display: "block", imageRendering: "pixelated" }}
        tabIndex={0}
      />

      {/* Gear / Customizer button */}
      <button
        onClick={() => setCustomizerOpen(true)}
        title="Customize character"
        style={{
          position: "fixed",
          top: "1rem",
          right: "1rem",
          zIndex: 50,
          width: "42px",
          height: "42px",
          borderRadius: "50%",
          background: "rgba(0,0,0,0.55)",
          border: "1.5px solid rgba(255,255,255,0.25)",
          backdropFilter: "blur(6px)",
          color: "#fff",
          fontSize: "1.2rem",
          cursor: "pointer",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          WebkitTapHighlightColor: "transparent",
          transition: "transform 0.2s",
        }}
        onMouseEnter={(e) => (e.currentTarget.style.transform = "rotate(30deg) scale(1.1)")}
        onMouseLeave={(e) => (e.currentTarget.style.transform = "")}
      >
        ⚙️
      </button>
      <HUD
        nearOption={anyOpen ? null : nearOption}
        onEnter={handleEnter}
      />

      {/* Pet dog prompt */}
      {!anyOpen && nearDog && !nearOption && !nearShop && (
        <div style={{
          position: "fixed",
          bottom: isMobile ? "9rem" : "2.5rem",
          left: "50%",
          transform: "translateX(-50%)",
          zIndex: 21,
          animation: "floatUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)",
        }}>
          <button
            onClick={() => { dogRef.current.happyTimer = 1.8; }}
            onTouchEnd={(e) => { e.preventDefault(); dogRef.current.happyTimer = 1.8; }}
            style={{
              background: "linear-gradient(135deg, #d97706cc, #92400ecc)",
              border: "2px solid #fbbf24",
              borderRadius: "50px",
              padding: isMobile ? "1rem 2.2rem" : "0.8rem 2rem",
              color: "#fff",
              fontSize: isMobile ? "1.1rem" : "1rem",
              fontWeight: "bold",
              cursor: "pointer",
              fontFamily: "Georgia, serif",
              letterSpacing: "0.03em",
              boxShadow: "0 0 24px #d9770688",
              display: "flex", alignItems: "center", gap: "0.5rem",
              WebkitTapHighlightColor: "transparent",
            }}
          >
            <span style={{ fontSize: isMobile ? "1.5rem" : "1.3rem" }}>🐕</span>
            Pet the dog!
            {!isMobile && <span style={{ fontSize: "0.75rem", opacity: 0.8, fontFamily: "sans-serif" }}>[E]</span>}
          </button>
        </div>
      )}

      {/* Shop enter prompt */}
      {!anyOpen && nearShop && !nearOption && (
        <div style={{
          position: "fixed",
          bottom: isMobile ? "9rem" : "2.5rem",
          left: "50%",
          transform: "translateX(-50%)",
          zIndex: 21,
          animation: "floatUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)",
        }}>
          <button
            onClick={handleEnterShop}
            onTouchEnd={(e) => { e.preventDefault(); handleEnterShop(); }}
            style={{
              background: `linear-gradient(135deg, ${nearShop.color}cc, ${nearShop.roofColor}cc)`,
              border: `2px solid ${nearShop.color}`,
              borderRadius: "50px",
              padding: isMobile ? "1rem 2.2rem" : "0.8rem 2rem",
              color: "#fff",
              fontSize: isMobile ? "1.1rem" : "1rem",
              fontWeight: "bold",
              cursor: "pointer",
              fontFamily: "Georgia, serif",
              letterSpacing: "0.03em",
              boxShadow: `0 0 24px ${nearShop.color}88`,
              display: "flex",
              alignItems: "center",
              gap: "0.5rem",
              WebkitTapHighlightColor: "transparent",
            }}
          >
            <span style={{ fontSize: isMobile ? "1.5rem" : "1.3rem" }}>{nearShop.emoji}</span>
            Visit {nearShop.label}
            {!isMobile && <span style={{ fontSize: "0.75rem", opacity: 0.8, fontFamily: "sans-serif" }}>[E]</span>}
          </button>
        </div>
      )}

      {isMobile && !anyOpen && (
        <Joystick onChange={handleJoystick} />
      )}

      {activeOption && activeOption.id !== "casino" && (
        <DateCard
          option={activeOption}
          onClose={() => {
            setActiveOption(null);
            activeOptionRef.current = null;
          }}
        />
      )}

      {activeShop && (
        <ShopNote
          shop={activeShop}
          onClose={() => {
            setActiveShop(null);
            activeShopRef.current = null;
          }}
        />
      )}

      {customizerOpen && (
        <Customizer
          config={charConfig}
          onChange={(cfg) => {
            setCharConfig(cfg);
            charConfigRef.current = cfg;
          }}
          onClose={() => setCustomizerOpen(false)}
        />
      )}

      {casinoOpen && (
        <Casino onClose={() => setCasinoOpen(false)} />
      )}
    </div>
  );
}
