function drawFlower(ctx: CanvasRenderingContext2D, x: number, y: number, color: string, type = "round", scale = 1) {
  const s = scale;
  const hy = y - 17 * s;
  // Stem
  ctx.fillStyle = "#4ade80";
  ctx.fillRect(x - 1.5 * s, y - 15 * s, 3 * s, 15 * s);

  if (type === "round") {
    ctx.fillStyle = color;
    for (let i = 0; i < 5; i++) {
      const a = (i / 5) * Math.PI * 2;
      ctx.beginPath();
      ctx.ellipse(x + Math.cos(a) * 6 * s, hy + Math.sin(a) * 6 * s, 4 * s, 4 * s, a, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.fillStyle = "#fde68a";
    ctx.beginPath(); ctx.arc(x, hy, 4 * s, 0, Math.PI * 2); ctx.fill();

  } else if (type === "daisy") {
    ctx.fillStyle = color;
    for (let i = 0; i < 8; i++) {
      const a = (i / 8) * Math.PI * 2;
      ctx.save(); ctx.translate(x, hy); ctx.rotate(a);
      ctx.beginPath(); ctx.ellipse(0, -7 * s, 2.5 * s, 6 * s, 0, 0, Math.PI * 2); ctx.fill();
      ctx.restore();
    }
    ctx.fillStyle = "#fbbf24";
    ctx.beginPath(); ctx.arc(x, hy, 4 * s, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = "#92400e";
    ctx.beginPath(); ctx.arc(x, hy, 2 * s, 0, Math.PI * 2); ctx.fill();

  } else if (type === "tulip") {
    ctx.fillStyle = color;
    for (let i = 0; i < 3; i++) {
      const a = (i / 3) * Math.PI * 2 - Math.PI / 2;
      ctx.beginPath();
      ctx.ellipse(x + Math.cos(a) * 5 * s, hy + Math.sin(a) * 4 * s, 5 * s, 7.5 * s, a - 0.3, 0, Math.PI * 2);
      ctx.fill();
    }
    // Leaf
    ctx.fillStyle = "#4ade80";
    ctx.beginPath();
    ctx.ellipse(x + 6 * s, y - 7 * s, 2 * s, 6 * s, 0.6, 0, Math.PI * 2);
    ctx.fill();

  } else if (type === "star") {
    ctx.fillStyle = color;
    for (let i = 0; i < 6; i++) {
      const a = (i / 6) * Math.PI * 2;
      ctx.save(); ctx.translate(x, hy); ctx.rotate(a);
      ctx.beginPath();
      ctx.moveTo(0, -9 * s); ctx.lineTo(2 * s, -3 * s);
      ctx.lineTo(0, -5 * s); ctx.lineTo(-2 * s, -3 * s);
      ctx.closePath(); ctx.fill();
      ctx.restore();
    }
    ctx.fillStyle = "#fde68a";
    ctx.beginPath(); ctx.arc(x, hy, 3.5 * s, 0, Math.PI * 2); ctx.fill();

  } else if (type === "clover") {
    ctx.fillStyle = color;
    for (let i = 0; i < 4; i++) {
      const a = (i / 4) * Math.PI * 2;
      ctx.beginPath();
      ctx.arc(x + Math.cos(a) * 5 * s, hy + Math.sin(a) * 5 * s, 4 * s, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.fillStyle = "#16a34a";
    ctx.beginPath(); ctx.arc(x, hy, 2.5 * s, 0, Math.PI * 2); ctx.fill();
  }
}

