  ctx.lineWidth = 1.5;
  ctx.strokeRect(x + 10, y + 28, 22, 22);
  ctx.strokeRect(x + w - 32, y + 28, 22, 22);

  // Window cross
  ctx.beginPath();
  ctx.moveTo(x + 21, y + 28); ctx.lineTo(x + 21, y + 50);
  ctx.moveTo(x + 10, y + 39); ctx.lineTo(x + 32, y + 39);
  ctx.moveTo(x + w - 21, y + 28); ctx.lineTo(x + w - 21, y + 50);
  ctx.moveTo(x + w - 32, y + 39); ctx.lineTo(x + w - 10, y + 39);
