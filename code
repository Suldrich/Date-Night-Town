) {
  const w = 96;
  const h = 80;
  const x = wx - w / 2;
  const y = wy - h / 2;

  if (isNear) {
    const pulse = 0.25 + Math.abs(Math.sin(time * 0.004)) * 0.2;
    const grad = ctx.createRadialGradient(wx, wy + 20, 0, wx, wy + 20, 80);
    grad.addColorStop(0, option.color + "99");
    grad.addColorStop(1, "transparent");
    ctx.globalAlpha = pulse;
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(wx, wy + 20, 80, 0, Math.PI * 2);
    ctx.fill();
    ctx.globalAlpha = 1;
  }

  // Foundation
  ctx.fillStyle = "#d4c5a9";
  ctx.fillRect(x - 4, y + h - 8, w + 8, 18);

  // Walls
  ctx.fillStyle = option.color;
  ctx.fillRect(x, y + 16, w, h - 16);

  // Wall shadow
  ctx.fillStyle = "rgba(0,0,0,0.15)";
  ctx.fillRect(x + w - 18, y + 16, 18, h - 16);

  // Door
  ctx.fillStyle = "#2d1b0e";
  ctx.fillRect(wx - 14, y + h - 36, 28, 36);
  // Door arch
  ctx.fillStyle = "#2d1b0e";
  ctx.beginPath();
  ctx.arc(wx, y + h - 36, 14, Math.PI, 0);
  ctx.fill();

  // Door knob
  ctx.fillStyle = "#fcd34d";
  ctx.beginPath();
  ctx.arc(wx + 9, y + h - 18, 4, 0, Math.PI * 2);
  ctx.fill();

  // Windows with glow tint
  const winColor = isNear ? "#fde68a" : "#93c5fd";
